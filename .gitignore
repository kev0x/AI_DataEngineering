# Purpose: Keeps generated, private, and machine-local files out of Git.
# Pipeline role: Protects personal financial data, DuckDB database files, local virtual environments, and frontend build output from being committed.
# Dependencies: Git ignore rules; update this when a new tool writes local-only files into the repo.

# OS/editor noise
.DS_Store
.idea/
.vscode/

# Local environment files
.env
.env.*
!.env.example

# Python local environment and caches
.venv/
venv/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Private source data, generated data, and local warehouse files
data/
warehouse/
*.duckdb
*.duckdb.wal
*.db
*.sqlite
*.sqlite3

# Frontend dependencies and build output
Frontend/node_modules/
Frontend/dist/
Frontend/.vite/

# Local Docker overrides
docker-compose.override.yml
Docker/docker-compose.override.yml

# Logs and temporary files
*.log
*.tmp
